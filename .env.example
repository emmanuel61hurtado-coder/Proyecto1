# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el archivo .env a git

# ── Flask ─────────────────────────────────────────────────────────────────────
# Clave secreta larga y aleatoria (genera una con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia-esta-clave-por-una-muy-segura-y-aleatoria

# Puerto de la app (Coolify o tu servidor lo asigna automáticamente)
PORT=5000

# ── PostgreSQL (Contenedor Independiente) ────────────────────────────────────
POSTGRES_DB=brujeria
POSTGRES_USER=brujeria_user
POSTGRES_PASSWORD=pon-aqui-una-contrasena-segura
POSTGRES_PORT=5432

# ── DATABASE_URL ─────────────────────────────────────────────────────────────
# Opción 1: Si PostgreSQL está en el contenedor independiente 'brujeria_db' (red brujeria_network)
DATABASE_URL=postgresql://brujeria_user:pon-aqui-una-contrasena-segura@brujeria_db:5432/brujeria

# Opción 2: Si PostgreSQL se conecta mediante la IP del host o localhost desde fuera de Docker
# DATABASE_URL=postgresql://brujeria_user:pon-aqui-una-contrasena-segura@host.docker.internal:5432/brujeria
