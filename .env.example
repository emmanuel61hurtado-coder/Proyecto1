# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el archivo .env a git

# ── Flask ─────────────────────────────────────────────────────────────────────
# Clave secreta larga y aleatoria (genera una con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=cambia-esta-clave-por-una-muy-segura-y-aleatoria

# Puerto de la app (Coolify lo asigna automáticamente)
PORT=5000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=brujeria
POSTGRES_USER=brujeria_user
POSTGRES_PASSWORD=pon-aqui-una-contrasena-segura

# DATABASE_URL es construida automáticamente por docker-compose.yml
# Si quieres sobreescribirla manualmente:
# DATABASE_URL=postgresql://brujeria_user:contrasena@db:5432/brujeria
